run = "npm run dev"
modules = ["nodejs-20"]

[env]
PORT = "3000"
NODE_ENV = "development"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm ci && npm run build"]
run = ["sh", "-c", "NODE_ENV=production node dist/index.js"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 80

[nix]
channel = "stable-25_05"
