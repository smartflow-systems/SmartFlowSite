# Database
DATABASE_URL=postgresql://user:password@localhost:5432/socialscalebooster

# Auth
JWT_SECRET=replace-with-a-long-random-string

# AI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# X / Twitter OAuth 2.0 (PKCE)
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_CALLBACK_URL=https://your-app.replit.app/api/integrations/twitter/callback

# Token encryption key — must be exactly 32+ characters, keep secret
TOKEN_ENCRYPTION_KEY=change-me-to-a-32-char-random-key!

# Server
PORT=3000
NODE_ENV=development
