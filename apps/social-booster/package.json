{
  "name": "socialscalebooster",
  "version": "0.1.0",
  "description": "Smartflow Store MVP API with Multi-Agent Orchestration",
  "main": "server.js",
  "private": true,
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:watch": "vitest watch",
    "migrate": "drizzle-kit generate && drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts",
    "pull": "git pull --no-edit",
    "push": "git push",
    "auto-commit": "git add . && git commit -m 'chore: auto-commit [Auto-Sync]' || true",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/client": "^5.22.0",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^7.9.0",
    "@tanstack/react-query": "^5.100.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "axios": "^1.13.1",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-day-picker": "^8.10.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.76.0",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "stripe": "^16.12.0",
    "vaul": "^1.1.2",
    "wouter": "^3.9.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^5.2.0",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "jsonwebtoken": "^9.0.3",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.0.15",
    "zod": "^4.1.13"
  },
  "engines": {
    "node": "22.x"
  }
}
